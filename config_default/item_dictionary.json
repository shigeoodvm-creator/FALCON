{
  "DIM": {
    "type": "calc",
    "origin": "calc",
    "data_type": "int",
    "formula": "dim(cow.get('clvd'))",
    "display_name": "分娩後日数"
  },
  "DPAI": {
    "type": "calc",
    "origin": "calc",
    "data_type": "int",
    "formula": "dpai(events)",
    "display_name": "最終AI後日数"
  },
  "DUE": {
    "type": "calc",
    "origin": "calc",
    "data_type": "str",
    "formula": "due_date(events, cow.get('clvd'))",
    "display_name": "分娩予定日"
  },
  "LAST_MILK_YIELD": {
    "type": "calc",
    "source": "601.milk_yield",
    "display_name": "最新乳量"
  },
  "LAST_FAT": {
    "type": "calc",
    "source": "601.fat",
    "display_name": "最新乳脂肪"
  },
  "LAST_PROTEIN": {
    "type": "calc",
    "source": "601.protein",
    "display_name": "最新乳タンパク"
  },
  "LAST_SNF": {
    "type": "calc",
    "source": "601.snf",
    "display_name": "最新無脂固形分"
  },
  "LAST_SCC": {
    "type": "calc",
    "source": "601.scc",
    "display_name": "最新体細胞数"
  },
  "LAST_LS": {
    "type": "calc",
    "source": "601.ls",
    "display_name": "最新LS"
  },
  "LAST_MUN": {
    "type": "calc",
    "source": "601.mun",
    "display_name": "最新MUN"
  },
  "LAST_BHB": {
    "type": "calc",
    "source": "601.bhb",
    "display_name": "最新BHB"
  },
  "LAST_DENOVO_FA": {
    "type": "calc",
    "origin": "calc",
    "data_type": "float",
    "formula": "latest_event_value(601, 'denovo_fa')",
    "display_name": "最新DeNovo FA"
  },
  "LAST_PREFORMED_FA": {
    "type": "calc",
    "source": "601.preformed_fa",
    "display_name": "最新Preformed FA"
  },
  "LAST_MIXED_FA": {
    "type": "calc",
    "source": "601.mixed_fa",
    "display_name": "最新Mixed FA"
  },
  "LAST_DENOVO_MILK": {
    "type": "calc",
    "source": "601.denovo_milk",
    "display_name": "最新DeNovo Milk"
  }
}